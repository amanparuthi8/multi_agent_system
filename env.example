# ============================================================
# Multi-Agent System — Environment Variables
# Copy to .env and fill values. Never commit .env.
# ============================================================

# ── Google Cloud / Vertex AI ─────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=1

# ── Model (gemini-2.5-flash from .md) ────────────────────────
MODEL=gemini-2.5-flash

# ── AlloyDB ─────────────────────────────────────────────────
ALLOYDB_PROJECT=your-project-id
ALLOYDB_REGION=us-central1
ALLOYDB_CLUSTER=mas-cluster
ALLOYDB_INSTANCE=mas-primary
ALLOYDB_DB=postgres
ALLOYDB_USER=postgres
ALLOYDB_PASSWORD=your-password
ALLOYDB_HOST=<alloydb-private-ip>
ALLOYDB_PORT=5432
# DATABASE_URL=postgresql+pg8000://postgres:password@<host>:5432/postgres

# ── MCP Toolbox ──────────────────────────────────────────────
MCP_TOOLBOX_URL=http://127.0.0.1:5000

# ── API ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
ALLOWED_ORIGINS=*

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
SQL_ECHO=false
